---
import Layout from '../layouts/BlogPost.astro';
import { Image } from 'astro:assets';
import vdirsyncerImage from '../assets/vdirsyncer.webp';
---

<Layout
	title="vdirsyncer personal integration"
	description="Personal synchronization setup using vdirsyncer and Google Cloud APIs."
	pubDate={new Date('2026-04-22')}
    category="Projects"
>
	<div class="project-container">
		<p>
            This page serves as the home for my personal integration of <strong>vdirsyncer</strong> 
            with Google Cloud services.
		</p>

        <div class="hero-image">
            <Image src={vdirsyncerImage} alt="vdirsyncer integration" class="vdir-img" />
        </div>

		<section>
			<h2>What is this?</h2>
			<p>
				<code>vdirsyncer</code> is a command-line tool for synchronizing calendars and 
                addressbooks between various servers and the local filesystem. 
                I use it to keep my Google Calendar in sync with my local calendar clients.
			</p>
		</section>

		<section>
			<h2>OAuth Verification</h2>
			<p>
				This application is configured for <strong>personal use only</strong>. 
                It uses the Google Calendar API to fetch and update calendar events. 
                The integration ensures that I can manage my schedule using open-source, 
                CLI-based tools while maintaining synchronization with Google's ecosystem.
			</p>
		</section>

		<section>
			<h2>Privacy and Security</h2>
			<p>
				All synchronization happens locally on my machines. No data is stored 
                by this website or shared with any third parties. 
                For more details, please see the <a href="/privacy">Privacy Policy</a>.
			</p>
		</section>
	</div>
</Layout>

<style>
	.project-container {
		max-width: 720px;
		margin: 0 auto;
	}

	section {
		margin-bottom: var(--space-8);
	}

	h2 {
		font-size: 1.2rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
		border-bottom: 1px solid var(--border-color);
		padding-bottom: var(--space-2);
		margin-bottom: var(--space-4);
	}

    p {
        margin-bottom: var(--space-4);
    }

    .hero-image {
        margin: var(--space-8) 0;
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
    }

    .vdir-img {
        width: 100%;
        height: auto;
        display: block;
    }

    a {
        color: var(--accent);
        text-decoration: underline;
    }
</style>
