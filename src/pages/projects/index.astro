---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const categories = [...new Set(projects.map(p => p.data.category))];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-header {
        margin-bottom: var(--space-16);
      }

      .page-header h1 {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        margin-bottom: var(--space-4);
      }

      .page-header p {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 600px;
        line-height: 1.6;
      }

      section {
        margin-bottom: var(--space-20);
      }

      .category-title {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--text-muted);
        margin-bottom: var(--space-10);
        display: flex;
        align-items: center;
        gap: var(--space-6);
      }

      .category-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: var(--space-6);
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="fade-in">
      <div class="page-header">
        <h1>Projects</h1>
        <p>Open source contributions for microbiome research, bioinformatics pipelines, and AI for Science.</p>
      </div>

      {categories.map(category => (
        <section>
          <h2 class="category-title">{category}</h2>
          <div class="project-grid">
            {projects
              .filter(p => p.data.category === category)
              .map(project => (
                <ProjectCard 
                  title={project.data.title}
                  description={project.data.description}
                  url={project.data.url}
                  tags={project.data.tags}
                  featured={project.data.featured}
                />
              ))
            }
          </div>
        </section>
      ))}
    </main>
    <Footer />
  </body>
</html>
