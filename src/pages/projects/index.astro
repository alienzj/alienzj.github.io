---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-header {
        margin-bottom: var(--space-12);
      }

      .page-header h1 {
        font-size: 2.5rem;
        margin-bottom: var(--space-4);
      }

      .page-header p {
        font-size: 1.2rem;
        color: var(--text-secondary);
      }

      section {
        margin-bottom: var(--space-12);
      }

      h2 {
        font-size: 1.4rem;
        border-bottom: 2px solid var(--border-color);
        padding-bottom: var(--space-2);
        margin-bottom: var(--space-6);
      }

      .project-list {
        list-style: none;
        padding: 0;
      }

      .project-item {
        margin-bottom: var(--space-8);
      }

      .project-title {
        font-size: 1.3rem;
        margin: 0 0 var(--space-2) 0;
      }

      .project-description {
        margin: 0 0 var(--space-4) 0;
        color: var(--text-secondary);
        line-height: 1.6;
      }

      .project-tags {
        display: flex;
        gap: var(--space-2);
        flex-wrap: wrap;
      }

      .tag {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.8rem;
        background: var(--border-color);
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        color: var(--text-secondary);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1>Projects</h1>
        <p>Open source contributions for microbiome research and AI for Science</p>
      </div>

      <section>
        <h2>OhMeta Projects</h2>
        <ul class="project-list">
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/ohmeta/metapi">metapi</a></h3>
            <p class="project-description">A general metagenomics data mining system for robust microbiome research.</p>
            <div class="project-tags">
              <span class="tag">Metagenomics</span>
              <span class="tag">Snakemake</span>
            </div>
          </li>
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/ohmeta/quantpi">quantpi</a></h3>
            <p class="project-description">Microbiome profiling pipeline with comprehensive QC and statistical analysis.</p>
            <div class="project-tags">
              <span class="tag">Metagenomics</span>
              <span class="tag">Profiling</span>
            </div>
          </li>
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/ohmeta/rnapi">rnapi</a></h3>
            <p class="project-description">RNA-seq analysis pipeline for transcriptomics studies.</p>
            <div class="project-tags">
              <span class="tag">RNA-seq</span>
              <span class="tag">Transcriptomics</span>
            </div>
          </li>
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/ohmeta/qiimepi">qiimepi</a></h3>
            <p class="project-description">Snakemake implementation of QIIME2 for amplicon analysis.</p>
            <div class="project-tags">
              <span class="tag">16S/ITS</span>
              <span class="tag">QIIME2</span>
            </div>
          </li>
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/ohmeta/skillpi">skillpi</a></h3>
            <p class="project-description">Knowledge base and skill management for scientific workflows.</p>
            <div class="project-tags">
              <span class="tag">Knowledge Base</span>
              <span class="tag">Workflow</span>
            </div>
          </li>
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/ohmeta/clawpi">clawpi</a></h3>
            <p class="project-description">AI-powered workflow orchestration and automated scientific discovery.</p>
            <div class="project-tags">
              <span class="tag">AI Agent</span>
              <span class="tag">Automation</span>
            </div>
          </li>
        </ul>
      </section>

      <section>
        <h2>Other Contributions</h2>
        <ul class="project-list">
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/metagenome-atlas/atlas">metagenome-atlas/atlas</a></h3>
            <p class="project-description">Automated metagenome analysis pipeline — "Three commands to analyze your metagenome".</p>
          </li>
          <li class="project-item">
            <h3 class="project-title"><a href="https://github.com/bioconda/bioconda-recipes">BioConda</a></h3>
            <p class="project-description">Contributor to the bioinformatics conda channel, participating in packaging and maintenance.</p>
          </li>
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
