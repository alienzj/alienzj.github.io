---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				padding: 2rem 1.5rem;
			}

			.page-header {
				margin-bottom: 2.5rem;
				padding-bottom: 1rem;
				border-bottom: 2px solid rgba(var(--gray-light), 80%);
			}

			.page-header h1 {
				margin: 0 0 0.5rem 0;
				font-size: 2rem;
				color: rgb(var(--black));
			}

			.page-header p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1.05rem;
			}

			.post-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.post-card {
				display: block;
				padding: 1.5rem;
				background: white;
				border-radius: 12px;
				border: 1px solid rgba(var(--gray-light), 60%);
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.post-card:hover {
				transform: translateX(4px);
				border-color: var(--accent);
				box-shadow: 0 4px 12px rgba(var(--gray), 10%);
			}

			.post-card:hover .post-title {
				color: var(--accent);
			}

			.post-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 0.75rem;
			}

			.post-title {
				margin: 0;
				font-size: 1.25rem;
				color: rgb(var(--gray-dark));
				font-weight: 600;
				line-height: 1.4;
			}

			.post-date {
				flex-shrink: 0;
				margin-left: 1rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				white-space: nowrap;
			}

			.post-description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.7;
			}

			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 1rem;
			}

			.tag {
				display: inline-block;
				padding: 0.25rem 0.75rem;
				background: rgba(var(--gray-light), 50%);
				color: rgb(var(--gray));
				border-radius: 20px;
				font-size: 0.8rem;
				font-weight: 500;
			}

			.empty-state {
				text-align: center;
				padding: 3rem 1rem;
				color: rgb(var(--gray));
			}

			.empty-state p {
				margin: 0;
				font-size: 1.05rem;
			}

			@media (max-width: 720px) {
				main {
					padding: 1.5rem 1rem;
				}

				.page-header h1 {
					font-size: 1.75rem;
				}

				.post-header {
					flex-direction: column;
					gap: 0.5rem;
				}

				.post-date {
					margin-left: 0;
				}

				.post-card {
					padding: 1.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blog</h1>
				<p>Thoughts on bioinformatics, genomics, and AI for Science</p>
			</div>

			{posts.length > 0 ? (
				<div class="post-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							<div class="post-header">
								<h2 class="post-title">{post.data.title}</h2>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</div>
							<p class="post-description">{post.data.description}</p>
							{post.data.tags && (
								<div class="post-tags">
									{post.data.tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							)}
						</a>
					))}
				</div>
			) : (
				<div class="empty-state">
					<p>No posts yet. Check back soon!</p>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
