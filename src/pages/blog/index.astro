---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-header {
        margin-bottom: var(--space-20);
        padding-bottom: var(--space-12);
        border-bottom: 1px solid var(--border);
      }

      .category-label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin-bottom: var(--space-4);
        display: block;
      }

      .page-header h1 {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.05em;
        margin-bottom: var(--space-6);
        line-height: 1;
      }

      .page-header p {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 650px;
        line-height: 1.6;
      }

      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
      }

      .post-item {
        position: relative;
      }

      .post-link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        padding: var(--space-8) var(--space-10);
        margin: 0 calc(var(--space-10) * -1);
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
      }

      .post-link:hover {
        background: var(--bg-tertiary);
      }

      .post-meta {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: var(--space-3);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }

      .post-meta .dot {
        width: 4px;
        height: 4px;
        background: var(--border-strong);
        border-radius: 50%;
      }

      .post-title {
        font-size: 1.875rem;
        font-weight: 700;
        margin: 0 0 var(--space-4) 0;
        color: var(--text-primary);
        letter-spacing: -0.03em;
        line-height: 1.2;
      }

      .post-description {
        margin: 0;
        color: var(--text-secondary);
        font-size: 1.0625rem;
        line-height: 1.6;
        max-width: 800px;
      }

      @media (max-width: 768px) {
        .page-header h1 {
          font-size: 2.75rem;
        }
        .post-link {
          padding: var(--space-6) var(--space-4);
          margin: 0 calc(var(--space-4) * -1);
        }
        .post-title {
          font-size: 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="fade-in">
      <div class="page-header">
        <span class="category-label">Archive</span>
        <h1 class="text-gradient">Blog</h1>
        <p>Research notes, technical deep dives, and thoughts on the future of microbiome informatics.</p>
      </div>

      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.id}/`} class="post-link">
              <div class="post-meta">
                <FormattedDate date={post.data.pubDate} />
                <span class="dot"></span>
                <span>{post.data.tags ? post.data.tags[0] : 'Article'}</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-description">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
