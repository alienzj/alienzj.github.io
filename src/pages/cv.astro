---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { SITE_TITLE } from '../consts';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`CV | ${SITE_TITLE}`} description="Curriculum Vitae" />
    <style>
      body {
        background: var(--bg-primary);
        margin: 0;
        padding: 0;
        font-family: var(--font-serif);
      }

      .cv-paper {
        background: var(--bg-primary);
        max-width: 800px;
        margin: var(--space-12) auto;
        padding: var(--space-12);
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid var(--border);
        min-height: 1100px;
        color: var(--text-primary);
      }

      :global(.dark) .cv-paper {
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        border-color: var(--border);
      }

      @media print {
        body { background: white; color: black; }
        .cv-paper { box-shadow: none; border: none; margin: 0; width: 100%; max-width: 100%; padding: 0; }
        .no-print { display: none; }
        .back-link, .theme-toggle-container { display: none; }
      }

      .header {
        text-align: center;
        margin-bottom: var(--space-10);
      }

      .header h1 {
        font-size: 2.5rem;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-weight: 700;
        font-family: var(--font-sans);
      }

      .contact-info {
        margin-top: var(--space-2);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      section {
        margin-bottom: var(--space-10);
      }

      h2 {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        border-bottom: 2px solid var(--text-primary);
        padding-bottom: 2px;
        margin-bottom: var(--space-4);
        font-weight: 800;
      }

      .cv-item {
        margin-bottom: var(--space-4);
      }

      .cv-list {
        list-style: none;
        padding: 0;
      }

      .cv-list li {
        margin-bottom: var(--space-3);
        line-height: 1.6;
        font-size: 1.05rem;
      }

      .cv-list li strong {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        background: var(--bg-tertiary);
        padding: 0.1rem 0.3rem;
        border-radius: var(--radius-sm);
        margin-right: var(--space-2);
      }

      .tech-stack {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
      }

      .tech-category h3 {
        font-family: var(--font-sans);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 var(--space-2) 0;
        color: var(--text-muted);
        font-weight: 700;
      }

      .tech-category p {
        font-size: 1rem;
        margin: 0;
        line-height: 1.5;
      }

      .back-link {
        position: fixed;
        top: 20px;
        left: 20px;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        text-decoration: none;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
      }

      .back-link:hover {
        color: var(--text-primary);
      }

      .theme-toggle-container {
        position: fixed;
        top: 20px;
        right: 20px;
      }
    </style>
  </head>
  <body>
    <a href="/about" class="back-link no-print">&larr; Back to About</a>
    <div class="theme-toggle-container no-print">
      <ThemeToggle />
    </div>
    
    <div class="cv-paper fade-in">
      <header class="header">
        <h1>alienzj</h1>
        <div class="contact-info">
          Bioinformatics Engineer | Researcher | alienzj.org
        </div>
      </header>

      <section>
        <h2>Personal Summary</h2>
        <p>
          Microbiome Informatics researcher and bioinformatics engineer dedicated to developing 
          robust tools for metagenomics data analysis. Focused on high-throughput pipeline 
          development, workflow automation, and AI-powered scientific discovery.
        </p>
      </section>

      <section>
        <h2>Technical Stack</h2>
        <div class="tech-stack">
          <div class="tech-category">
            <h3>Metagenomics</h3>
            <p>ATLAS, MetaPhlAn, HUMAnN, MEGAHIT, CheckM, GTDB-Tk, QIIME2</p>
          </div>
          <div class="tech-category">
            <h3>Workflow & Ops</h3>
            <p>Snakemake, Nextflow, Docker, Singularity, Conda, GitHub Actions</p>
          </div>
          <div class="tech-category">
            <h3>Data Science</h3>
            <p>Python (pandas, numpy, scikit-learn), R (tidyverse, phyloseq)</p>
          </div>
          <div class="tech-category">
            <h3>AI & Agents</h3>
            <p>LLM orchestration, LangChain, Autonomous Agents for Science</p>
          </div>
        </div>
      </section>

      <section>
        <h2>Open Source Projects</h2>
        <ul class="cv-list">
          {projects.map(project => (
            <li><strong>{project.data.title}</strong>: {project.data.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Research Interests</h2>
        <ul class="cv-list">
          <li>Recovery and analysis of Metagenome-Assembled Genomes (MAGs).</li>
          <li>Microbiome data mining and functional profiling.</li>
          <li>Reproducible research through workflow automation.</li>
          <li>Artificial Intelligence for scientific discovery (AI4Science).</li>
        </ul>
      </section>

      <section>
        <h2>Links</h2>
        <ul class="cv-list">
          <li>GitHub: github.com/alienzj</li>
          <li>Organization: github.com/ohmeta</li>
          <li>Website: alienzj.org</li>
        </ul>
      </section>
    </div>
  </body>
</html>
