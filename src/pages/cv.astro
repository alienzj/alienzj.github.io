---
import BaseHead from '../components/BaseHead.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`CV | ${SITE_TITLE}`} description="Curriculum Vitae" />
    <style>
      body {
        background: var(--bg-primary);
        margin: 0;
        padding: 0;
        font-family: Georgia, serif;
      }

      .cv-paper {
        background: var(--bg-primary);
        max-width: 800px;
        margin: var(--space-12) auto;
        padding: var(--space-12);
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid var(--border-color);
        min-height: 1100px;
      }

      :global(.dark) .cv-paper {
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
      }

      @media print {
        body { background: white; }
        .cv-paper { box-shadow: none; border: none; margin: 0; width: 100%; max-width: 100%; }
        .no-print { display: none; }
      }

      .header {
        text-align: center;
        margin-bottom: var(--space-10);
      }

      .header h1 {
        font-size: 2.5rem;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .contact-info {
        margin-top: var(--space-2);
        font-family: -apple-system, sans-serif;
        font-size: 0.9rem;
        color: var(--text-secondary);
      }

      section {
        margin-bottom: var(--space-8);
      }

      h2 {
        font-family: -apple-system, sans-serif;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-bottom: 2px solid var(--text-primary);
        padding-bottom: 2px;
        margin-bottom: var(--space-4);
      }

      .cv-item {
        margin-bottom: var(--space-4);
      }

      .cv-item-header {
        display: flex;
        justify-content: space-between;
        font-weight: bold;
      }

      .cv-list {
        list-style: none;
        padding: 0;
      }

      .cv-list li {
        margin-bottom: var(--space-2);
        line-height: 1.5;
      }

      .tech-stack {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
      }

      .tech-category h3 {
        font-family: -apple-system, sans-serif;
        font-size: 0.9rem;
        margin: 0 0 var(--space-1) 0;
      }

      .tech-category p {
        font-size: 0.9rem;
        margin: 0;
      }

      .back-link {
        position: fixed;
        top: 20px;
        left: 20px;
        font-family: -apple-system, sans-serif;
        font-size: 0.9rem;
        text-decoration: none;
        color: var(--text-muted);
      }

      .back-link:hover {
        color: var(--text-primary);
      }

      .theme-toggle-container {
        position: fixed;
        top: 20px;
        right: 20px;
      }
    </style>
  </head>
  <body>
    <a href="/about" class="back-link no-print">&larr; Back to About</a>
    <div class="theme-toggle-container no-print">
      <ThemeToggle />
    </div>
    
    <div class="cv-paper">
      <header class="header">
        <h1>alienzj</h1>
        <div class="contact-info">
          Bioinformatics Engineer | Researcher | alienzj.tech
        </div>
      </header>

      <section>
        <h2>Personal Summary</h2>
        <p>
          Microbiome Informatics researcher and bioinformatics engineer dedicated to developing 
          robust tools for metagenomics data analysis. Focused on high-throughput pipeline 
          development, workflow automation, and AI-powered scientific discovery.
        </p>
      </section>

      <section>
        <h2>Technical Stack</h2>
        <div class="tech-stack">
          <div class="tech-category">
            <h3>Metagenomics</h3>
            <p>ATLAS, MetaPhlAn, HUMAnN, MEGAHIT, CheckM, GTDB-Tk, QIIME2</p>
          </div>
          <div class="tech-category">
            <h3>Workflow & Ops</h3>
            <p>Snakemake, Nextflow, Docker, Singularity, Conda, GitHub Actions</p>
          </div>
          <div class="tech-category">
            <h3>Data Science</h3>
            <p>Python (pandas, numpy, scikit-learn), R (tidyverse, phyloseq)</p>
          </div>
          <div class="tech-category">
            <h3>AI & Agents</h3>
            <p>LLM orchestration, LangChain, Autonomous Agents for Science</p>
          </div>
        </div>
      </section>

      <section>
        <h2>Open Source Projects</h2>
        <ul class="cv-list">
          <li><strong>metapi</strong>: General metagenomics data mining system for robust research.</li>
          <li><strong>quantpi</strong>: Microbiome profiling pipeline with comprehensive QC.</li>
          <li><strong>rnapi</strong>: RNA-seq analysis pipeline for transcriptomics.</li>
          <li><strong>qiimepi</strong>: Snakemake implementation of QIIME2 for amplicon analysis.</li>
          <li><strong>skillpi</strong>: Knowledge base and skill management for scientific workflows.</li>
          <li><strong>clawpi</strong>: AI-powered workflow orchestration and discovery.</li>
          <li><strong>ATLAS (Contributor)</strong>: Automated metagenome analysis pipeline.</li>
        </ul>
      </section>

      <section>
        <h2>Research Interests</h2>
        <ul class="cv-list">
          <li>Recovery and analysis of Metagenome-Assembled Genomes (MAGs).</li>
          <li>Microbiome data mining and functional profiling.</li>
          <li>Reproducible research through workflow automation.</li>
          <li>Artificial Intelligence for scientific discovery (AI4Science).</li>
        </ul>
      </section>

      <section>
        <h2>Links</h2>
        <ul class="cv-list">
          <li>GitHub: github.com/alienzj</li>
          <li>Organization: github.com/ohmeta</li>
          <li>Website: alienzj.tech</li>
        </ul>
      </section>
    </div>
  </body>
</html>
