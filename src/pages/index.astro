---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: var(--space-16) 0 var(--space-20);
      }

      .hero h1 {
        font-size: clamp(3.5rem, 10vw, 5.5rem);
        font-weight: 800;
        letter-spacing: -0.06em;
        line-height: 0.95;
        margin-bottom: var(--space-8);
      }

      .hero p {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 680px;
        line-height: 1.6;
        margin-bottom: var(--space-6);
      }

      .hero p strong {
        color: var(--text-primary);
        font-weight: 600;
      }

      .section-title {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--text-muted);
        margin-bottom: var(--space-10);
        display: flex;
        align-items: center;
        gap: var(--space-6);
      }

      .section-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      section {
        margin-bottom: var(--space-24);
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: var(--space-4);
      }

      .project-card {
        padding: var(--space-8);
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        background: var(--bg-primary);
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .project-card:hover {
        border-color: var(--accent);
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.1);
      }

      .project-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 var(--space-3) 0;
        color: var(--text-primary);
        letter-spacing: -0.02em;
      }

      .project-card p {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.6;
      }

      .blog-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
      }

      .blog-item {
        position: relative;
      }

      .blog-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-decoration: none;
        padding: var(--space-4) var(--space-6);
        margin: 0 calc(var(--space-6) * -1);
        border-radius: var(--radius-md);
        transition: all 0.2s ease;
      }

      .blog-link:hover {
        background: var(--bg-tertiary);
      }

      .blog-link .title {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 1.125rem;
        letter-spacing: -0.01em;
      }

      .blog-link .date {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .view-all {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        margin-top: var(--space-10);
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--text-primary);
        text-decoration: none;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .view-all:hover {
        gap: var(--space-3);
      }

      @media (max-width: 640px) {
        .hero h1 {
          font-size: 3rem;
        }
        .blog-link {
          flex-direction: column;
          align-items: flex-start;
          gap: var(--space-2);
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="fade-in">
      <section class="hero">
        <h1 class="text-gradient">alienzj</h1>
        <p>
          <strong>Microbiome Informatics Researcher</strong> & Bioinformatics Engineer.
          Dedicated to deciphering the microbial world through metagenomics, 
          computational ecology, and AI-powered scientific workflows.
        </p>
        <p>
          Co-founder of <a href="https://github.com/ohmeta">OhMeta</a> and active contributor to 
          <a href="https://github.com/snakemake">Snakemake</a>, 
          <a href="https://github.com/bioconda">BioConda</a>, and 
          <a href="https://github.com/metagenome-atlas">Metagenome Atlas</a>.
        </p>
      </section>

      <section>
        <h2 class="section-title">Selected Projects</h2>
        <div class="project-grid">
          <a href="https://github.com/ohmeta/metapi" class="project-card">
            <h3>metapi</h3>
            <p>A general metagenomics data mining system designed for high-performance computing.</p>
          </a>
          <a href="https://github.com/ohmeta/quantpi" class="project-card">
            <h3>quantpi</h3>
            <p>Microbiome profiling and statistical analysis toolkit for large-scale studies.</p>
          </a>
          <a href="https://github.com/ohmeta/clawpi" class="project-card">
            <h3>clawpi</h3>
            <p>AI-powered workflow orchestration and intelligent agent for scientific analysis.</p>
          </a>
        </div>
        <a href="/projects" class="view-all">View all projects &rarr;</a>
      </section>

      <section>
        <h2 class="section-title">Latest Writing</h2>
        <ul class="blog-list">
          {posts.map((post) => (
            <li class="blog-item">
              <a href={`/blog/${post.id}/`} class="blog-link">
                <span class="title">{post.data.title}</span>
                <span class="date"><FormattedDate date={post.data.pubDate} /></span>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="view-all">Read more articles &rarr;</a>
      </section>

      <section>
        <h2 class="section-title">Contact</h2>
        <ul class="blog-list">
          <li class="blog-item">
            <a href="https://github.com/alienzj" class="blog-link">
              <span class="title">GitHub (@alienzj)</span>
              <span class="date">Source & Open Science</span>
            </a>
          </li>
          <li class="blog-item">
            <a href="/about" class="blog-link">
              <span class="title">About & CV</span>
              <span class="date">Background & Focus</span>
            </a>
          </li>
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
