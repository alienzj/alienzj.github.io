---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="bio">
        <h1>alienzj</h1>
        <p>
          Microbiome Informatics Researcher & Bioinformatics Engineer.
          Focusing on metagenomics, MAGs, and AI-powered scientific workflows.
          Passionate about open-source science and community-driven tool development.
        </p>
        <p>
          I am a co-founder of <a href="https://github.com/ohmeta">OhMeta</a> and a 
          contributor to <a href="https://github.com/snakemake">Snakemake</a>, 
          <a href="https://github.com/bioconda">BioConda</a>, and 
          <a href="https://github.com/metagenome-atlas">Metagenome Atlas</a>.
        </p>
      </section>

      <section class="projects">
        <h2>Selected Projects</h2>
        <ul>
          <li>
            <strong><a href="https://github.com/ohmeta/metapi">metapi</a></strong>: 
            A general metagenomics data mining system.
          </li>
          <li>
            <strong><a href="https://github.com/ohmeta/quantpi">quantpi</a></strong>: 
            Microbiome profiling and statistical analysis.
          </li>
          <li>
            <strong><a href="https://github.com/ohmeta/clawpi">clawpi</a></strong>: 
            AI-powered workflow orchestration.
          </li>
        </ul>
        <p><a href="/projects">View all projects &rarr;</a></p>
      </section>

      <section class="blog-preview">
        <h2>Recent Blog Posts</h2>
        <ul>
          <li>
            <a href="/blog/velvet-genome-assembler">Velvet 基因组组装器详解：从论文到 C 代码实现</a>
            <span>(Mar 13, 2026)</span>
          </li>
        </ul>
        <p><a href="/blog">Read the blog &rarr;</a></p>
      </section>

      <section class="links">
        <h2>Links</h2>
        <ul>
          <li><a href="https://github.com/alienzj">GitHub (@alienzj)</a></li>
          <li><a href="https://alienzj.tech">Personal Website (alienzj.tech)</a></li>
          <li><a href="/about">About & Curriculum Vitae</a></li>
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bio h1 {
    font-size: 3rem;
    margin-bottom: var(--space-6);
  }

  .bio p {
    font-size: 1.2rem;
    color: var(--text-primary);
    max-width: 700px;
  }

  section {
    margin-bottom: var(--space-12);
  }

  h2 {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-6);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    margin-bottom: var(--space-4);
    line-height: 1.5;
  }

  span {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-left: var(--space-2);
  }
</style>
