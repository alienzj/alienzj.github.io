---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>alienzj</h1>
			<p class="intro">
				Microbiome Informatics researcher and bioinformatics engineer.
				Building tools for metagenomics, MAGs, and AI-powered scientific workflows.
			</p>

			<section class="sections">
				<div class="section-card">
					<h3>🔬 Research</h3>
					<p>Metagenome-assembled genomes (MAGs), microbiome data mining, workflow automation with Snakemake and Nextflow.</p>
				</div>
				<div class="section-card">
					<h3>🤖 AI for Science</h3>
					<p>LLM-powered agents for scientific workflows, automated literature review, and intelligent data analysis.</p>
				</div>
				<div class="section-card">
					<h3>📦 Open Source</h3>
					<p>Contributor to <a href="https://github.com/ohmeta">OhMeta</a>, <a href="https://github.com/metagenome-atlas/atlas">ATLAS</a>, <a href="https://github.com/bioconda">BioConda</a>, and <a href="https://github.com/snakemake">Snakemake</a>.</p>
				</div>
				<div class="section-card">
					<h3>🌱 Personal</h3>
					<p>INFJ • Cycling • HomeLab • Indie games • Balancing code and nature.</p>
				</div>
			</section>

			<h2>Navigate</h2>
			<ul class="nav-list">
				<li><a href="/cv">📄 Curriculum Vitae</a> — Research interests, skills, and projects</li>
				<li><a href="/blog">📝 Blog</a> — Thoughts on bioinformatics, AI, and scientific computing</li>
				<li><a href="/about">👤 About</a> — My journey and philosophy</li>
				<li><a href="https://github.com/alienzj" target="_blank" rel="noopener">🐙 GitHub</a> — Open-source contributions</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		font-size: 1.125rem;
		line-height: 1.8;
		color: #57606a;
		margin-bottom: 2.5rem;
	}

	.sections {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-bottom: 2.5rem;
	}

	.section-card {
		padding: 1.25rem;
		background: #f6f8fa;
		border-radius: 8px;
		border: 1px solid #eaeef2;
	}

	.section-card:hover {
		border-color: #0366d6;
	}

	.section-card h3 {
		margin: 0 0 0.5rem 0;
		font-size: 1rem;
	}

	.section-card p {
		margin: 0;
		font-size: 0.925rem;
		color: #57606a;
		line-height: 1.6;
	}

	.section-card a {
		color: #0366d6;
	}

	.nav-list {
		list-style: none;
		padding: 0;
	}

	.nav-list li {
		padding: 0.75rem 0;
		border-bottom: 1px solid #eaeef2;
	}

	.nav-list li:last-child {
		border-bottom: none;
	}

	.nav-list a {
		color: #0366d6;
		font-weight: 500;
	}

	@media (max-width: 600px) {
		.sections {
			grid-template-columns: 1fr;
		}
	}
</style>
