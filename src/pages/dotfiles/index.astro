---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { groupBySection, sectionOrder } from '../../lib/doc-categories';

const docs = await getCollection('dotfiles');
const sidebar = groupBySection(docs.map((d) => ({ slug: d.id })));
const totalDocs = docs.length;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Dotfiles | alienzj" description="Fully hermetic NixOS dotfiles flake — 9 hosts, modular architecture, security hardening, impermanent root." />
    <style>
      /* ── Hero ─────────────────────────────────────────────────── */
      .hero {
        text-align: center;
        padding: var(--space-20) var(--space-6) var(--space-12);
        max-width: 720px;
        margin: 0 auto;
      }
      .hero h1 {
        font-size: 3.25rem;
        font-weight: 800;
        letter-spacing: -0.05em;
        margin-bottom: var(--space-4);
        line-height: 1.1;
      }
      .hero p {
        font-size: 1.125rem;
        color: var(--text-secondary);
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto var(--space-8);
      }
      .hero-links {
        display: flex;
        justify-content: center;
        gap: var(--space-3);
        flex-wrap: wrap;
      }
      .hero-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        font-weight: 600;
        padding: var(--space-2) var(--space-5);
        border-radius: 9999px;
        text-decoration: none;
        transition: all 0.2s;
      }
      .hero-link.primary {
        background: var(--accent);
        color: #fff;
      }
      .hero-link.primary:hover { filter: brightness(1.1); }
      .hero-link.secondary {
        border: 1px solid var(--border);
        color: var(--text-secondary);
      }
      .hero-link.secondary:hover { border-color: var(--accent); color: var(--accent); }

      /* ── Stats ────────────────────────────────────────────────── */
      .stats {
        display: flex;
        justify-content: center;
        gap: var(--space-12);
        padding: var(--space-8) var(--space-6);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        margin-bottom: var(--space-16);
      }
      .stat {
        text-align: center;
      }
      .stat-number {
        font-size: 2rem;
        font-weight: 800;
        font-family: var(--font-mono);
        color: var(--accent);
        line-height: 1;
      }
      .stat-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: var(--space-1);
      }

      /* ── Main Layout ──────────────────────────────────────────── */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 var(--space-6) var(--space-20);
      }

      /* ── Section ──────────────────────────────────────────────── */
      .section {
        margin-bottom: var(--space-16);
      }
      .section-header {
        display: flex;
        align-items: baseline;
        gap: var(--space-4);
        margin-bottom: var(--space-6);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--border);
      }
      .section-header h2 {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.02em;
        margin: 0;
      }
      .section-header .count {
        font-size: 0.75rem;
        font-family: var(--font-mono);
        color: var(--text-muted);
      }

      /* ── Cards Grid ───────────────────────────────────────────── */
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: var(--space-3);
      }
      .card {
        display: block;
        padding: var(--space-5);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: all 0.2s;
        background: var(--bg-primary);
      }
      .card:hover {
        border-color: var(--accent);
        background: var(--bg-secondary);
        transform: translateY(-1px);
      }
      .card-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: var(--space-1);
        letter-spacing: -0.01em;
      }
      .card-slug {
        font-size: 0.6875rem;
        font-family: var(--font-mono);
        color: var(--text-muted);
      }

      /* ── Responsive ───────────────────────────────────────────── */
      @media (max-width: 768px) {
        .hero h1 { font-size: 2.25rem; }
        .stats { gap: var(--space-6); }
        .stat-number { font-size: 1.5rem; }
        .cards { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero -->
      <div class="hero">
        <h1 class="text-gradient">NixOS Dotfiles</h1>
        <p>
          A fully hermetic, modular NixOS flake composing <strong>9 hosts</strong>
          across workstations, servers, SBCs, and VPS. Zero impure dependencies.
          Built on a custom Janet CLI (<code>hey</code>) for declarative ops.
        </p>
        <div class="hero-links">
          <a href="/dotfiles/README/" class="hero-link primary">Overview &rarr;</a>
          <a href="/dotfiles/CLAUDE/" class="hero-link secondary">Agent Guide</a>
          <a href="https://github.com/alienzj/dotfiles" class="hero-link secondary" target="_blank" rel="noopener">
            GitHub
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats">
        <div class="stat">
          <div class="stat-number">9</div>
          <div class="stat-label">Hosts</div>
        </div>
        <div class="stat">
          <div class="stat-number">{totalDocs}</div>
          <div class="stat-label">Docs</div>
        </div>
        <div class="stat">
          <div class="stat-number">16</div>
          <div class="stat-label">CLI Commands</div>
        </div>
        <div class="stat">
          <div class="stat-number">7</div>
          <div class="stat-label">Security Layers</div>
        </div>
      </div>

      <!-- Doc Sections -->
      <div class="container">
        {sidebar.map((group) => (
          <div class="section">
            <div class="section-header">
              <h2>{group.section}</h2>
              <span class="count">{group.items.length} doc{group.items.length !== 1 ? 's' : ''}</span>
            </div>
            <div class="cards">
              {group.items.map((item) => (
                <a href={`/dotfiles/${item.slug}/`} class="card">
                  <div class="card-title">{item.title}</div>
                  <div class="card-slug">docs/{item.slug}.md</div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
