---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getImage } from 'astro:assets';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

let optimizedImage;
if (heroImage) {
	try {
		optimizedImage = await getImage({ src: heroImage, width: 1020, height: 510, format: 'jpeg' });
	} catch (e) {
		optimizedImage = null;
	}
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				max-width: 720px;
				padding: 3rem 1.5rem;
			}

			article {
				padding-bottom: 3rem;
			}

			.hero-image {
				margin-bottom: 2rem;
			}

			.hero-image img {
				display: block;
				width: 100%;
				max-width: 1020px;
				height: auto;
				margin: 0 auto;
				border-radius: 8px;
			}

			.article-header {
				margin-bottom: 2.5rem;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1rem;
				color: #57606a;
				font-size: 0.875rem;
			}

			.article-date {
				display: flex;
				align-items: center;
				gap: 0.375rem;
			}

			.last-updated-on {
				font-style: italic;
			}

			.article-title {
				margin: 0 0 0.75rem 0;
				font-size: 2rem;
				line-height: 1.3;
				letter-spacing: -0.02em;
			}

			.article-description {
				margin: 0;
				font-size: 1.125rem;
				color: #57606a;
				line-height: 1.7;
			}

			.article-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.375rem;
				margin-top: 1rem;
			}

			.tag {
				display: inline-block;
				padding: 0.25rem 0.625rem;
				background: #f6f8fa;
				color: #57606a;
				border-radius: 12px;
				font-size: 0.8rem;
			}

			/* Prose styles */
			.prose {
				color: #24292f;
				line-height: 1.75;
			}

			.prose > * {
				margin-top: 1.5rem;
				margin-bottom: 0;
			}

			.prose > :first-child {
				margin-top: 0;
			}

			.prose > h1,
			.prose > h2,
			.prose > h3,
			.prose > h4,
			.prose > h5,
			.prose > h6 {
				margin-top: 2.5rem;
				color: #24292f;
			}

			.prose > h1 { font-size: 1.75rem; }
			.prose > h2 { font-size: 1.5rem; }
			.prose > h3 { font-size: 1.25rem; }
			.prose > h4 { font-size: 1.125rem; }

			.prose > h2 {
				padding-bottom: 0.5rem;
				border-bottom: 1px solid #eaeef2;
			}

			.prose > p {
				margin-top: 1.25rem;
			}

			.prose > ul,
			.prose > ol {
				margin-top: 1.25rem;
				padding-left: 1.5rem;
			}

			.prose > ul li,
			.prose > ol li {
				margin: 0.375rem 0;
			}

			.prose > blockquote {
				margin: 1.25rem 0;
				padding: 0.75rem 1rem 0.75rem 1.25rem;
				background: #f6f8fa;
				border-left: 3px solid #0366d6;
				border-radius: 0 6px 6px 0;
				font-style: italic;
				color: #57606a;
			}

			.prose > blockquote p {
				margin: 0;
			}

			.prose > pre {
				margin: 1.25rem 0;
				padding: 0;
				background: #1e1e1e;
				border-radius: 8px;
				overflow: hidden;
			}

			.prose > pre code {
				display: block;
				padding: 1.25rem;
				overflow-x: auto;
				font-size: 0.85rem;
				line-height: 1.6;
				color: #e5e5e5;
			}

			.prose > :not(pre) > code {
				padding: 0.125rem 0.375rem;
				background: #f6f8fa;
				border-radius: 4px;
				font-size: 0.85em;
				color: #24292f;
			}

			.prose > hr {
				margin: 2rem 0;
				border: none;
				border-top: 1px solid #eaeef2;
			}

			.prose > table {
				width: 100%;
				margin: 1.25rem 0;
				border-collapse: collapse;
				font-size: 0.925rem;
			}

			.prose > table th,
			.prose > table td {
				padding: 0.625rem 0.75rem;
				border: 1px solid #eaeef2;
				text-align: left;
			}

			.prose > table th {
				background: #f6f8fa;
				font-weight: 600;
			}

			.prose > a {
				color: #0366d6;
				text-decoration: none;
				border-bottom: 1px solid transparent;
			}

			.prose > a:hover {
				border-bottom-color: #0366d6;
			}

			.prose > img {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
				margin: 1.5rem 0;
			}

			/* Post footer */
			.post-footer {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid #eaeef2;
				color: #57606a;
				font-size: 0.875rem;
			}

			@media (max-width: 720px) {
				main {
					padding: 2rem 1rem;
				}

				.article-title {
					font-size: 1.625rem;
				}

				.article-description {
					font-size: 1.05rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{optimizedImage && (
					<div class="hero-image">
						<img
							src={optimizedImage.src}
							width={optimizedImage.width}
							height={optimizedImage.height}
							alt=""
							loading="lazy"
						/>
					</div>
				)}

				<div class="article-header">
					<div class="article-meta">
						<span class="article-date">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
								<line x1="16" y1="2" x2="16" y2="6"></line>
								<line x1="8" y1="2" x2="8" y2="6"></line>
								<line x1="3" y1="10" x2="21" y2="10"></line>
							</svg>
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="last-updated-on">
								· Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>

					<h1 class="article-title">{title}</h1>
					<p class="article-description">{description}</p>

					{tags && tags.length > 0 && (
						<div class="article-tags">
							{tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)}
				</div>

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
