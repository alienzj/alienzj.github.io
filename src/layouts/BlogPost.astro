---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      /* Main layout - wider content area */
      .blog-wrapper {
        display: grid;
        grid-template-columns: 200px minmax(0, 1fr) 280px;
        gap: var(--space-10);
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 var(--space-6);
      }

      /* Left sidebar - navigation */
      .blog-sidebar-left {
        position: sticky;
        top: var(--space-6);
        height: fit-content;
        grid-column: 1;
      }

      /* Main content area */
      .blog-content {
        grid-column: 2;
        min-width: 0;
      }

      /* Right sidebar - TOC */
      .blog-sidebar-right {
        position: sticky;
        top: var(--space-6);
        height: fit-content;
        grid-column: 3;
      }

      /* Article header styles */
      .article-header {
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-6);
        border-bottom: 1px solid var(--border-color);
      }

      .article-meta {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: var(--space-3);
        display: flex;
        align-items: center;
        gap: var(--space-2);
      }

      .article-title {
        font-size: 2rem;
        margin-top: 0;
        margin-bottom: var(--space-3);
        line-height: 1.25;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .article-description {
        font-size: 1.05rem;
        font-style: italic;
        color: var(--text-secondary);
        margin-bottom: var(--space-4);
        line-height: 1.6;
      }

      .article-tags {
        display: flex;
        gap: var(--space-2);
        flex-wrap: wrap;
      }

      .tag {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.75rem;
        background: var(--border-color);
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.2s;
      }

      .tag:hover {
        background: var(--accent);
        color: var(--bg-primary);
      }

      /* Hero image */
      .hero-image {
        margin: 0 calc(-1 * var(--space-6)) var(--space-8);
      }

      .hero-image img {
        width: calc(100% + var(--space-12));
        max-height: 400px;
        object-fit: cover;
        border-radius: 12px;
      }

      /* Content typography */
      .prose {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--text-primary);
      }

      .prose :global(h2) {
        margin-top: var(--space-10);
        margin-bottom: var(--space-3);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-primary);
      }

      .prose :global(h3) {
        margin-top: var(--space-8);
        margin-bottom: var(--space-2);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .prose :global(h4) {
        margin-top: var(--space-6);
        margin-bottom: var(--space-2);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .prose :global(p) {
        margin-bottom: var(--space-4);
      }

      .prose :global(a) {
        color: var(--text-primary);
        text-decoration: underline;
        text-decoration-color: var(--text-muted);
        text-underline-offset: 3px;
        transition: all 0.2s;
      }

      .prose :global(a:hover) {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      .prose :global(pre) {
        margin: var(--space-5) 0;
        padding: var(--space-4);
        border-radius: 8px;
        border: 1px solid var(--border-color);
      }

      .prose :global(code) {
        font-family: "JetBrains Mono", "Fira Code", monospace;
        font-size: 0.9em;
        background: var(--border-color);
        padding: 0.15em 0.4em;
        border-radius: 4px;
      }

      .prose :global(pre code) {
        background: transparent;
        padding: 0;
      }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: var(--space-4);
        padding-left: var(--space-6);
      }

      .prose :global(li) {
        margin-bottom: var(--space-2);
      }

      .prose :global(li > ul),
      .prose :global(li > ol) {
        margin-top: var(--space-2);
        margin-bottom: 0;
      }

      .prose :global(table) {
        font-size: 0.95rem;
        margin-bottom: var(--space-5);
        width: 100%;
        border-collapse: collapse;
      }

      .prose :global(th) {
        text-align: left;
        padding: var(--space-3) var(--space-4);
        border-bottom: 2px solid var(--border-color);
        font-weight: 600;
        color: var(--text-primary);
      }

      .prose :global(td) {
        padding: var(--space-3) var(--space-4);
        border-bottom: 1px solid var(--border-color);
        color: var(--text-secondary);
      }

      .prose :global(tr:last-child td) {
        border-bottom: none;
      }

      .prose :global(blockquote) {
        margin: var(--space-6) 0;
        padding: var(--space-3) var(--space-4);
        border-left: 4px solid var(--accent);
        background: var(--border-color);
        border-radius: 0 6px 6px 0;
        font-style: italic;
        color: var(--text-secondary);
      }

      .prose :global(blockquote > p:last-child) {
        margin-bottom: 0;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--border-color);
        margin: var(--space-10) 0;
      }

      .prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: var(--space-6) 0;
      }

      .prose :global(.admonition) {
        padding: var(--space-4);
        border-radius: 8px;
        margin: var(--space-6) 0;
        border-left: 4px solid;
      }

      .prose :global(.admonition-note) {
        background: rgba(59, 130, 246, 0.1);
        border-color: #3b82f6;
      }

      .prose :global(.admonition-warning) {
        background: rgba(245, 158, 11, 0.1);
        border-color: #f59e0b;
      }

      .prose :global(.admonition-danger) {
        background: rgba(239, 68, 68, 0.1);
        border-color: #ef4444;
      }

      /* Post footer */
      .post-footer {
        margin-top: var(--space-12);
        padding-top: var(--space-6);
        border-top: 1px solid var(--border-color);
        font-size: 0.9rem;
      }

      .post-footer a {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.2s;
      }

      .post-footer a:hover {
        color: var(--accent);
      }

      /* Responsive design */
      @media (max-width: 1200px) {
        .blog-wrapper {
          grid-template-columns: 1fr 280px;
        }

        .blog-sidebar-left {
          display: none;
        }

        .blog-content {
          grid-column: 1;
        }

        .blog-sidebar-right {
          grid-column: 2;
        }
      }

      @media (max-width: 900px) {
        .blog-wrapper {
          grid-template-columns: 1fr;
          max-width: 800px;
        }

        .blog-sidebar-right {
          display: none;
        }

        .hero-image {
          margin: 0 0 var(--space-6);
        }

        .hero-image img {
          width: 100%;
        }
      }

      @media (max-width: 640px) {
        .article-title {
          font-size: 1.6rem;
        }

        .prose {
          font-size: 1rem;
        }

        .blog-wrapper {
          padding: 0 var(--space-4);
        }
      }

      /* Dark mode specific adjustments */
      :global(.dark) .prose :global(pre) {
        border-color: #333;
      }

      :global(.dark) .prose :global(table) {
        border-color: #333;
      }

      :global(.dark) .prose :global(th) {
        border-bottom-color: #444;
      }

      :global(.dark) .prose :global(td) {
        border-bottom-color: #333;
      }

      :global(.dark) .prose :global(blockquote) {
        background: rgba(255, 255, 255, 0.05);
      }
    </style>
  </head>

  <body>
    <Header />
    <main class="blog-wrapper">
      <!-- Left sidebar - can be used for navigation -->
      <aside class="blog-sidebar-left">
        <!-- Reserved for future navigation -->
      </aside>

      <!-- Main content -->
      <article class="blog-content">
        <header class="article-header">
          <div class="article-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span> · Updated <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1 class="article-title">{title}</h1>
          <p class="article-description">{description}</p>
          {tags && (
            <div class="article-tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </header>

        {heroImage && (
          <div class="hero-image">
            <img src={heroImage} alt="" />
          </div>
        )}

        <div class="prose">
          <slot />
        </div>

        <footer class="post-footer">
          <a href="/blog">&larr; Back to blog</a>
        </footer>
      </article>

      <!-- Right sidebar - Table of Contents -->
      <aside class="blog-sidebar-right">
        <TableOfContents />
      </aside>
    </main>
    <Footer />
  </body>
</html>
