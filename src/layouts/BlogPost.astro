---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
    <style>
      .blog-wrapper {
        display: grid;
        grid-template-columns: 1fr min(220px, 20%);
        gap: var(--space-8);
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 var(--space-6);
      }

      .blog-content {
        min-width: 0;
        max-width: 720px;
      }

      .blog-sidebar {
        position: relative;
      }

      /* Article header */
      .article-header {
        margin-bottom: var(--space-8);
      }

      .article-meta {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: var(--space-4);
      }

      .article-meta span {
        display: flex;
        align-items: center;
        gap: var(--space-1);
      }

      .article-title {
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -0.03em;
        margin: 0 0 var(--space-4);
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .article-description {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-secondary);
        margin: 0 0 var(--space-5);
        font-style: italic;
      }

      .article-tags {
        display: flex;
        gap: var(--space-2);
        flex-wrap: wrap;
      }

      .tag {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.3rem 0.75rem;
        border-radius: 20px;
        background: var(--border-color);
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid transparent;
      }

      .tag:hover {
        background: var(--accent);
        color: white;
        transform: translateY(-1px);
      }

      /* Hero image */
      .hero-image {
        margin: var(--space-6) 0 var(--space-8);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }

      .hero-image img {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        display: block;
      }

      /* Content typography */
      .prose {
        font-size: 1.0625rem;
        line-height: 1.8;
        color: var(--text-primary);
      }

      .prose :global(h2) {
        margin-top: var(--space-12);
        margin-bottom: var(--space-4);
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        scroll-margin-top: 120px;
        position: relative;
        padding-bottom: var(--space-2);
      }

      .prose :global(h2)::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 40px;
        height: 2px;
        background: var(--accent);
        border-radius: 1px;
      }

      .prose :global(h3) {
        margin-top: var(--space-10);
        margin-bottom: var(--space-3);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
        scroll-margin-top: 100px;
      }

      .prose :global(h4) {
        margin-top: var(--space-8);
        margin-bottom: var(--space-2);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        scroll-margin-top: 80px;
      }

      .prose :global(p) {
        margin-bottom: var(--space-5);
      }

      .prose :global(a) {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: all 0.2s;
      }

      .prose :global(a:hover) {
        border-bottom-color: var(--accent);
      }

      .prose :global(pre) {
        margin: var(--space-6) 0;
        padding: var(--space-5);
        background: var(--code-bg);
        border-radius: 10px;
        border: 1px solid var(--border-color);
        overflow-x: auto;
        position: relative;
      }

      .prose :global(pre)::before {
        content: '';
        position: absolute;
        top: 12px;
        left: 16px;
        width: 8px;
        height: 8px;
        background: #ef4444;
        border-radius: 50%;
        box-shadow: 14px 0 0 #f59e0b, 28px 0 0 #22c55e;
        opacity: 0.8;
      }

      .prose :global(pre) {
        padding-top: var(--space-8);
      }

      .prose :global(code) {
        font-family: "JetBrains Mono", "Fira Code", ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas, monospace;
        font-size: 0.875em;
        background: var(--code-bg);
        padding: 0.2em 0.4em;
        border-radius: 4px;
        border: 1px solid var(--border-color);
      }

      .prose :global(pre code) {
        background: transparent;
        padding: 0;
        border: none;
        font-size: 0.875rem;
        line-height: 1.6;
      }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: var(--space-5);
        padding-left: var(--space-6);
      }

      .prose :global(li) {
        margin-bottom: var(--space-2);
        position: relative;
      }

      .prose :global(ul li::marker) {
        color: var(--accent);
      }

      .prose :global(ol li::marker) {
        color: var(--accent);
        font-weight: 600;
      }

      .prose :global(blockquote) {
        margin: var(--space-8) 0;
        padding: var(--space-5) var(--space-6);
        border-left: 3px solid var(--accent);
        background: var(--bg-secondary);
        border-radius: 0 8px 8px 0;
        color: var(--text-secondary);
        font-style: italic;
        position: relative;
      }

      .prose :global(blockquote)::before {
        content: '"';
        position: absolute;
        top: -10px;
        left: 20px;
        font-size: 4rem;
        color: var(--accent);
        opacity: 0.2;
        font-family: Georgia, serif;
        line-height: 1;
      }

      .prose :global(blockquote > *:last-child) {
        margin-bottom: 0;
      }

      .prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: var(--space-8) 0;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
      }

      .prose :global(hr) {
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border-color), transparent);
        margin: var(--space-12) 0;
      }

      .prose :global(table) {
        width: 100%;
        margin: var(--space-6) 0;
        border-collapse: collapse;
        font-size: 0.95rem;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--border-color);
      }

      .prose :global(th) {
        background: var(--bg-secondary);
        padding: var(--space-3) var(--space-4);
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid var(--border-color);
      }

      .prose :global(td) {
        padding: var(--space-3) var(--space-4);
        border-bottom: 1px solid var(--border-color);
      }

      .prose :global(tr:last-child td) {
        border-bottom: none;
      }

      /* Post footer */
      .post-footer {
        margin-top: var(--space-16);
        padding-top: var(--space-8);
        border-top: 1px solid var(--border-color);
      }

      .post-footer a {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.2s;
      }

      .post-footer a:hover {
        color: var(--accent);
        transform: translateX(-4px);
      }

      .post-footer a svg {
        transition: transform 0.2s;
      }

      .post-footer a:hover svg {
        transform: translateX(-4px);
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .blog-wrapper {
          grid-template-columns: 1fr;
          max-width: 720px;
        }

        .blog-sidebar {
          display: none;
        }
      }

      @media (max-width: 640px) {
        .blog-wrapper {
          padding: 0 var(--space-4);
        }

        .article-title {
          font-size: 1.75rem;
        }

        .article-description {
          font-size: 1.05rem;
        }

        .prose {
          font-size: 1rem;
          line-height: 1.75;
        }

        .prose :global(h2) {
          font-size: 1.35rem;
        }

        .prose :global(h3) {
          font-size: 1.15rem;
        }
      }

      /* Dark mode */
      :global(.dark) .hero-image {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      }

      :global(.dark) .prose :global(pre) {
        border-color: #2a2a2a;
      }

      :global(.dark) .prose :global(img) {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
      }
    </style>
  </head>

  <body>
    <Header />
    <main class="blog-wrapper">
      <article class="blog-content">
        <header class="article-header">
          <div class="article-meta">
            <span><FormattedDate date={pubDate} /></span>
            {updatedDate && (
              <span>· Updated <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1 class="article-title">{title}</h1>
          {description && <p class="article-description">{description}</p>}
          {tags && tags.length > 0 && (
            <div class="article-tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </header>

        {heroImage && (
          <div class="hero-image">
            {typeof heroImage === 'string' ? (
              <img src={heroImage} alt="" loading="lazy" />
            ) : (
              <Image src={heroImage} alt="" loading="lazy" />
            )}
          </div>
        )}

        <div class="prose">
          <slot />
        </div>

        <footer class="post-footer">
          <a href="/blog">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to blog
          </a>
        </footer>
      </article>

      <aside class="blog-sidebar">
        <TableOfContents />
      </aside>
    </main>
    <Footer />
  </body>
</html>