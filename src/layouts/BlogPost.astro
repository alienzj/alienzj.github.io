---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getImage } from 'astro:assets';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

let optimizedImage;
if (heroImage) {
	try {
		optimizedImage = await getImage({ src: heroImage, width: 1020, height: 510, format: 'jpeg' });
	} catch (e) {
		optimizedImage = null;
	}
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				max-width: 800px;
				padding: 0 1.5rem;
			}

			article {
				padding: 2rem 0 4rem;
			}

			.hero-image {
				margin-bottom: 2rem;
			}

			.hero-image img {
				display: block;
				width: 100%;
				max-width: 1020px;
				height: auto;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
			}

			.article-header {
				margin-bottom: 2.5rem;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1rem;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}

			.article-date {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.last-updated-on {
				font-style: italic;
			}

			.article-title {
				margin: 0;
				font-size: 2.25rem;
				color: rgb(var(--black));
				line-height: 1.3;
				letter-spacing: -0.02em;
			}

			.article-description {
				margin: 1rem 0 0 0;
				font-size: 1.15rem;
				color: rgb(var(--gray));
				line-height: 1.7;
			}

			.article-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 1.5rem;
			}

			.tag {
				display: inline-block;
				padding: 0.35rem 0.875rem;
				background: rgba(var(--gray-light), 50%);
				color: rgb(var(--gray));
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 500;
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.tag:hover {
				background: var(--accent);
				color: white;
			}

			/* Prose styles for markdown content */
			.prose {
				color: rgb(var(--gray-dark));
				line-height: 1.8;
			}

			.prose > p {
				margin: 1.5rem 0;
			}

			.prose > h1,
			.prose > h2,
			.prose > h3,
			.prose > h4,
			.prose > h5,
			.prose > h6 {
				margin-top: 2.5rem;
				margin-bottom: 1rem;
				color: rgb(var(--black));
				font-weight: 600;
				line-height: 1.3;
			}

			.prose > h1 { font-size: 2rem; }
			.prose > h2 { font-size: 1.5rem; }
			.prose > h3 { font-size: 1.25rem; }
			.prose > h4 { font-size: 1.125rem; }

			.prose > h2 {
				padding-bottom: 0.5rem;
				border-bottom: 2px solid rgba(var(--gray-light), 80%);
			}

			.prose > ul,
			.prose > ol {
				margin: 1.5rem 0;
				padding-left: 1.5rem;
			}

			.prose > ul li,
			.prose > ol li {
				margin: 0.5rem 0;
				line-height: 1.7;
			}

			.prose > blockquote {
				margin: 1.5rem 0;
				padding: 1rem 1.25rem;
				background: rgba(var(--gray-light), 30%);
				border-left: 4px solid var(--accent);
				border-radius: 0 8px 8px 0;
				font-style: italic;
				color: rgb(var(--gray));
			}

			.prose > blockquote p {
				margin: 0;
			}

			.prose > pre {
				margin: 1.5rem 0;
				padding: 0;
				background: #1e1e1e;
				border-radius: 8px;
				overflow: hidden;
			}

			.prose > pre code {
				display: block;
				padding: 1.25rem;
				overflow-x: auto;
				font-size: 0.9rem;
				line-height: 1.6;
				color: #d4d4d4;
			}

			.prose > :not(pre) > code {
				padding: 0.2rem 0.5rem;
				background: rgba(var(--gray-light), 50%);
				border-radius: 4px;
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
			}

			.prose > hr {
				margin: 2.5rem 0;
				border: none;
				border-top: 2px solid rgba(var(--gray-light), 80%);
			}

			.prose > table {
				width: 100%;
				margin: 1.5rem 0;
				border-collapse: collapse;
				font-size: 0.95rem;
			}

			.prose > table th,
			.prose > table td {
				padding: 0.75rem 1rem;
				border: 1px solid rgba(var(--gray-light), 80%);
				text-align: left;
			}

			.prose > table th {
				background: rgba(var(--gray-light), 40%);
				font-weight: 600;
			}

			.prose > table tr:nth-child(even) {
				background: rgba(var(--gray-light), 20%);
			}

			.prose > a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s ease;
			}

			.prose > a:hover {
				border-bottom-color: var(--accent);
			}

			.prose > img {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
				margin: 1.5rem 0;
			}

			/* Post footer */
			.post-footer {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 2px solid rgba(var(--gray-light), 80%);
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}

			@media (max-width: 720px) {
				main {
					padding: 0 1rem;
				}

				article {
					padding: 1.5rem 0 3rem;
				}

				.article-title {
					font-size: 1.75rem;
				}

				.article-description {
					font-size: 1.05rem;
				}

				.prose > h1 { font-size: 1.625rem; }
				.prose > h2 { font-size: 1.375rem; }
				.prose > h3 { font-size: 1.125rem; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{optimizedImage && (
					<div class="hero-image">
						<img
							src={optimizedImage.src}
							width={optimizedImage.width}
							height={optimizedImage.height}
							alt=""
							loading="lazy"
						/>
					</div>
				)}

				<div class="article-header">
					<div class="article-meta">
						<span class="article-date">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
								<line x1="16" y1="2" x2="16" y2="6"></line>
								<line x1="8" y1="2" x2="8" y2="6"></line>
								<line x1="3" y1="10" x2="21" y2="10"></line>
							</svg>
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="last-updated-on">
								· Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>

					<h1 class="article-title">{title}</h1>
					<p class="article-description">{description}</p>

					{tags && tags.length > 0 && (
						<div class="article-tags">
							{tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)}
				</div>

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
