---
interface Props {
  title?: string;
}

const { title = 'On this page' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-title">{title}</div>
  <ul class="toc-list" id="toc-list">
    <!-- TOC items will be populated by JavaScript -->
  </ul>
</nav>

<script>
  interface TOCItem {
    id: string;
    text: string;
    depth: number;
    element: Element;
    top: number;
    bottom: number;
  }

  let tocItems: TOCItem[] = [];
  let activeId: string | null = null;
  let ticking: boolean = false;

  function getArticle() {
    return document.querySelector('article.blog-content') ||
           document.querySelector('article.blog-main') ||
           document.querySelector('article .prose')?.closest('article') ||
           document.querySelector('article');
  }

  function generateTOC() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    const article = getArticle();
    if (!article) return;

    const headings = article.querySelectorAll('h2, h3, h4');

    if (headings.length === 0) {
      const tocEl = document.querySelector('.toc');
      if (tocEl) tocEl.style.display = 'none';
      return;
    }

    tocItems = Array.from(headings).map(heading => {
      if (!heading.id) {
        heading.id = heading.textContent
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '');
      }

      return {
        id: heading.id,
        text: heading.textContent || '',
        depth: parseInt(heading.tagName.charAt(1)),
        element: heading,
        top: 0,
        bottom: 0
      };
    });

    updatePositions();

    tocList.innerHTML = '';
    tocItems.forEach(item => {
      const li = document.createElement('li');
      li.className = `toc-item toc-depth-${item.depth}`;

      const a = document.createElement('a');
      a.href = `#${item.id}`;
      a.textContent = item.text;
      a.dataset.tocLink = item.id;  // Store ID in dataset
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const linkId = e.currentTarget.dataset.tocLink;
        const target = document.getElementById(linkId);
        if (target) {
          const headerOffset = 80;
          const elementPosition = target.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
          history.pushState(null, '', `#${linkId}`);
        }
      });

      li.appendChild(a);
      tocList.appendChild(li);
    });

    initScrollSpy();
  }

  function updatePositions() {
    const headerOffset = 80;
    tocItems.forEach((item, index) => {
      const rect = item.element.getBoundingClientRect();
      item.top = rect.top + window.pageYOffset - headerOffset;
      
      // Calculate bottom as the position of the next heading or end of page
      const nextItem = tocItems[index + 1];
      if (nextItem) {
        const nextRect = nextItem.element.getBoundingClientRect();
        item.bottom = nextRect.top + window.pageYOffset - headerOffset - 1;
      } else {
        // Last item: use document end
        item.bottom = document.documentElement.scrollHeight;
      }
    });
  }

  function initScrollSpy() {
    const handleScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updatePositions();

          const scrollPos = window.pageYOffset || document.documentElement.scrollTop;
          // Use a point slightly below the top of viewport for better UX
          const scanPoint = scrollPos + 120;

          let currentId: string | null = null;

          // Find which section the scan point is in
          for (let i = 0; i < tocItems.length; i++) {
            const item = tocItems[i];
            
            if (scanPoint >= item.top && scanPoint < item.bottom) {
              currentId = item.id;
              break;
            }
          }

          // If no section found, use the last one we passed
          if (!currentId) {
            for (let i = tocItems.length - 1; i >= 0; i--) {
              if (scanPoint >= tocItems[i].top) {
                currentId = tocItems[i].id;
                break;
              }
            }
          }

          if (currentId !== activeId) {
            activeId = currentId;
            updateActiveLink();
          }

          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', () => {
      updatePositions();
      handleScroll();
    }, { passive: true });

    // Initial check
    setTimeout(() => {
      updatePositions();
      handleScroll();
    }, 100);
  }

  function updateActiveLink() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    // Remove active class from all links
    tocList.querySelectorAll('.toc-item a').forEach(link => {
      link.classList.remove('active');
    });

    // Add active class to current link
    if (activeId) {
      const activeLink = tocList.querySelector(`a[data-toc-link="${activeId}"]`);
      if (activeLink) {
        activeLink.classList.add('active');
        
        // Auto-scroll TOC to keep active item visible
        const tocContainer = document.querySelector('.toc');
        if (tocContainer) {
          const linkRect = activeLink.getBoundingClientRect();
          const containerRect = tocContainer.getBoundingClientRect();
          
          if (linkRect.top < containerRect.top + 40) {
            activeLink.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          } else if (linkRect.bottom > containerRect.bottom - 40) {
            activeLink.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
        }
      }
    }
  }

  generateTOC();
  document.addEventListener('astro:page-load', generateTOC);
</script>

<style>
  .toc {
    position: sticky;
    top: var(--space-6);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: var(--space-3) var(--space-3);
    max-height: calc(100vh - var(--space-10));
    overflow-y: auto;
    overflow-x: hidden;
    transition: border-color 0.2s;
  }

  .toc:hover {
    border-color: var(--text-muted);
  }

  .toc-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
    position: relative;
  }

  .toc-item a {
    display: block;
    padding: 3px var(--space-2);
    margin: 0 calc(-1 * var(--space-2));
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.7rem;
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1.35;
    border-radius: 4px;
    transition: all 0.15s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-left: 2px solid transparent;
    padding-left: calc(var(--space-2) - 2px);
  }

  .toc-item a:hover {
    color: var(--text-primary);
    background: var(--border-color);
  }

  .toc-item a.active {
    color: var(--accent);
    font-weight: 600;
    background: rgba(59, 130, 246, 0.08);
    border-left-color: var(--accent);
  }

  .toc-depth-3 {
    padding-left: calc(var(--space-3) + 2px);
  }

  .toc-depth-3 a {
    padding-left: calc(var(--space-3) - 2px);
  }

  .toc-depth-4 {
    padding-left: calc(var(--space-5) + 2px);
  }

  .toc-depth-4 a {
    padding-left: calc(var(--space-5) - 2px);
  }

  /* Custom scrollbar */
  .toc::-webkit-scrollbar {
    width: 3px;
  }

  .toc::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 2px;
  }

  .toc::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }

  @media (max-width: 1200px) {
    .toc {
      display: none;
    }
  }
</style>
