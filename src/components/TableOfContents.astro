---
interface Props {
  title?: string;
}

const { title = 'Contents' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-header">
    <span class="toc-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </span>
    <span class="toc-title">{title}</span>
  </div>
  <ul class="toc-list" id="toc-list"></ul>
</nav>

<script is:inline>
  (function() {
    let tocItems = [];
    let activeId = null;
    let ticking = false;
    const headerOffset = 100;

    function getArticle() {
      return document.querySelector('article.blog-content') ||
             document.querySelector('article.blog-main') ||
             document.querySelector('article');
    }

    function slugify(text) {
      return text
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
    }

    function generateTOC() {
      const tocList = document.getElementById('toc-list');
      const tocEl = document.querySelector('.toc');
      if (!tocList) return;

      const article = getArticle();
      if (!article) {
        if (tocEl) tocEl.style.display = 'none';
        return;
      }

      const headings = Array.from(article.querySelectorAll('h2, h3, h4'));
      
      if (headings.length === 0) {
        if (tocEl) tocEl.style.display = 'none';
        return;
      }

      // Hide header if only 1 item
      const headerEl = document.querySelector('.toc-header');
      if (headerEl) {
        headerEl.style.display = headings.length <= 1 ? 'none' : 'flex';
      }

      tocItems = headings.map((heading, index) => {
        if (!heading.id) {
          heading.id = slugify(heading.textContent || '') || 'heading-' + index;
        }
        return {
          id: heading.id,
          text: heading.textContent || '',
          depth: parseInt(heading.tagName.charAt(1)) - 1,
          element: heading,
          top: 0,
          bottom: 0
        };
      });

      tocList.innerHTML = '';
      tocItems.forEach((item, index) => {
        const li = document.createElement('li');
        li.className = `toc-item depth-${item.depth}`;
        li.style.setProperty('--index', index);

        const a = document.createElement('a');
        a.href = `#${item.id}`;
        a.className = 'toc-link';
        a.textContent = item.text;
        a.setAttribute('data-toc-id', item.id);

        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Click handler
      tocList.addEventListener('click', (e) => {
        const link = e.target.closest('.toc-link');
        if (!link) return;
        e.preventDefault();
        
        const id = link.getAttribute('data-toc-id');
        const target = document.getElementById(id);
        if (target) {
          const targetPos = target.getBoundingClientRect().top + window.scrollY - headerOffset;
          window.scrollTo({ top: targetPos, behavior: 'smooth' });
          history.pushState(null, '', `#${id}`);
        }
      });

      // Init scroll spy
      setTimeout(initScrollSpy, 100);
    }

    function updatePositions() {
      tocItems.forEach((item, index) => {
        const rect = item.element.getBoundingClientRect();
        item.top = rect.top + window.scrollY - headerOffset;
        
        const nextItem = tocItems[index + 1];
        if (nextItem) {
          const nextRect = nextItem.element.getBoundingClientRect();
          item.bottom = nextRect.top + window.scrollY - headerOffset;
        } else {
          item.bottom = document.documentElement.scrollHeight;
        }
      });
    }

    function handleScroll() {
      if (tocItems.length === 0) return;
      
      const scrollY = window.scrollY;
      const scanPoint = scrollY + headerOffset + 20;

      let newActiveId = null;
      for (let i = tocItems.length - 1; i >= 0; i--) {
        if (scanPoint >= tocItems[i].top) {
          newActiveId = tocItems[i].id;
          break;
        }
      }

      if (newActiveId !== activeId) {
        activeId = newActiveId;
        updateActiveState();
      }
    }

    function initScrollSpy() {
      updatePositions();
      handleScroll();

      if (window._tocScrollHandler) {
        window.removeEventListener('scroll', window._tocScrollHandler);
      }

      window._tocScrollHandler = () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updatePositions();
            handleScroll();
            ticking = false;
          });
          ticking = true;
        }
      };

      window.addEventListener('scroll', window._tocScrollHandler, { passive: true });
      window.addEventListener('resize', () => {
        updatePositions();
        handleScroll();
      }, { passive: true });
    }

    function updateActiveState() {
      const tocList = document.getElementById('toc-list');
      if (!tocList) return;

      tocList.querySelectorAll('.toc-link').forEach(link => {
        link.classList.remove('active');
      });

      if (activeId) {
        const activeLink = tocList.querySelector(`[data-toc-id="${activeId}"]`);
        if (activeLink) {
          activeLink.classList.add('active');
          
          // Smooth scroll within TOC
          activeLink.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }
    }

    // Initialize
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', generateTOC);
    } else {
      generateTOC();
    }

    document.addEventListener('astro:page-load', generateTOC);
    document.addEventListener('astro:after-swap', generateTOC);
  })();
</script>

<style>
  .toc {
    --toc-active-bg: rgba(59, 130, 246, 0.08);
    --toc-active-color: var(--accent);
    --toc-hover-bg: rgba(0, 0, 0, 0.04);
    --toc-border: var(--border-color);
    --toc-text: var(--text-secondary);
    --toc-text-muted: var(--text-muted);
    
    background: var(--bg-primary);
    border: 1px solid var(--toc-border);
    border-radius: 8px;
    padding: 0;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    overflow-x: hidden;
    font-size: 0.75rem;
    transition: all 0.2s ease;
  }

  .dark .toc {
    --toc-hover-bg: rgba(255, 255, 255, 0.04);
  }

  .toc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--toc-border);
    position: sticky;
    top: 0;
    background: var(--bg-primary);
    z-index: 1;
  }

  .toc-icon {
    color: var(--toc-text-muted);
    display: flex;
    align-items: center;
    opacity: 0.6;
  }

  .toc-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--toc-text-muted);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 8px 0;
  }

  .toc-item {
    margin: 0;
    position: relative;
    animation: fadeSlideIn 0.3s ease forwards;
    animation-delay: calc(var(--index) * 30ms);
    opacity: 0;
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateX(-8px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .toc-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--toc-text);
    text-decoration: none;
    border-radius: 0;
    transition: all 0.15s ease;
    position: relative;
  }

  .toc-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 0;
    background: var(--toc-active-color);
    border-radius: 1px;
    transition: height 0.2s ease;
  }

  .toc-link:hover {
    color: var(--text-primary);
    background: var(--toc-hover-bg);
  }

  .toc-link.active {
    color: var(--toc-active-color);
    font-weight: 500;
    background: var(--toc-active-bg);
  }

  .toc-link.active::before {
    height: 60%;
  }

  /* Depth indentation */
  .depth-1 {
    padding-left: 8px;
  }
  .depth-1 .toc-link {
    padding-left: 24px;
  }

  .depth-2 {
    padding-left: 16px;
  }
  .depth-2 .toc-link {
    padding-left: 32px;
    font-size: 0.7rem;
  }

  .depth-3 {
    padding-left: 24px;
  }
  .depth-3 .toc-link {
    padding-left: 40px;
    font-size: 0.7rem;
    color: var(--toc-text-muted);
  }

  /* Progress indicator */
  .toc::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: var(--scroll-progress, 0%);
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-hover));
    transition: width 0.1s linear;
    z-index: 100;
  }

  /* Custom scrollbar */
  .toc::-webkit-scrollbar {
    width: 4px;
  }

  .toc::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc::-webkit-scrollbar-thumb {
    background: var(--toc-border);
    border-radius: 2px;
  }

  .toc::-webkit-scrollbar-thumb:hover {
    background: var(--toc-text-muted);
  }

  @media (max-width: 1200px) {
    .toc {
      display: none;
    }
  }
</style>