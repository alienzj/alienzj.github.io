---
interface Props {
  title?: string;
}

const { title = 'On this page' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-title">{title}</div>
  <ul class="toc-list" id="toc-list">
    <!-- TOC items will be populated by JavaScript -->
  </ul>
</nav>

<script>
  interface TOCItem {
    id: string;
    text: string;
    depth: number;
    element: Element;
    top: number;
  }

  let tocItems: TOCItem[] = [];
  let activeId: string | null = null;
  let ticking: boolean = false;

  function getArticle() {
    return document.querySelector('article.blog-content') ||
           document.querySelector('article.blog-main') ||
           document.querySelector('article .prose')?.closest('article') ||
           document.querySelector('article');
  }

  function generateTOC() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    const article = getArticle();
    if (!article) return;

    const headings = article.querySelectorAll('h2, h3, h4');

    if (headings.length === 0) {
      const tocEl = document.querySelector('.toc');
      if (tocEl) tocEl.style.display = 'none';
      return;
    }

    tocItems = Array.from(headings).map(heading => {
      if (!heading.id) {
        heading.id = heading.textContent
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '');
      }

      return {
        id: heading.id,
        text: heading.textContent || '',
        depth: parseInt(heading.tagName.charAt(1)),
        element: heading,
        top: 0
      };
    });

    // Update positions
    updatePositions();

    tocList.innerHTML = '';
    tocItems.forEach(item => {
      const li = document.createElement('li');
      li.className = `toc-item toc-depth-${item.depth}`;
      li.dataset.tocId = item.id;

      const a = document.createElement('a');
      a.href = `#${item.id}`;
      a.textContent = item.text;
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(item.id);
        if (target) {
          const headerOffset = 100;
          const elementPosition = target.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
          history.pushState(null, '', `#${item.id}`);
        }
      });

      li.appendChild(a);
      tocList.appendChild(li);
    });

    initScrollSpy();
  }

  function updatePositions() {
    const headerOffset = 100;
    tocItems.forEach(item => {
      const rect = item.element.getBoundingClientRect();
      item.top = rect.top + window.pageYOffset - headerOffset;
    });
  }

  function initScrollSpy() {
    const handleScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updatePositions();
          
          const scrollPos = window.pageYOffset || document.documentElement.scrollTop;
          const viewportMiddle = scrollPos + window.innerHeight * 0.35;
          
          let currentId: string | null = null;

          for (let i = 0; i < tocItems.length; i++) {
            const item = tocItems[i];
            const nextItem = tocItems[i + 1];
            
            if (item.top <= scrollPos + 120) {
              if (nextItem && nextItem.top > scrollPos + 120) {
                currentId = item.id;
                break;
              }
              currentId = item.id;
            }
          }

          if (currentId !== activeId) {
            activeId = currentId;
            updateActiveLink();
          }
          
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', updatePositions, { passive: true });
    
    setTimeout(handleScroll, 50);
  }

  function updateActiveLink() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    tocList.querySelectorAll('.toc-item a').forEach(link => {
      link.classList.remove('active');
    });

    if (activeId) {
      const activeLink = tocList.querySelector(`a[href="#${activeId}"]`);
      if (activeLink) {
        activeLink.classList.add('active');
      }
    }
  }

  generateTOC();
  document.addEventListener('astro:page-load', generateTOC);
</script>

<style>
  .toc {
    position: sticky;
    top: var(--space-6);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: var(--space-3) var(--space-3);
    max-height: calc(100vh - var(--space-10));
    overflow-y: auto;
    overflow-x: hidden;
    transition: border-color 0.2s;
  }

  .toc:hover {
    border-color: var(--text-muted);
  }

  .toc-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-item a {
    display: block;
    padding: 2px var(--space-2);
    margin: 0 calc(-1 * var(--space-2));
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1.4;
    border-radius: 3px;
    transition: all 0.12s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .toc-item a:hover {
    color: var(--text-primary);
    background: var(--border-color);
  }

  .toc-item a.active {
    color: var(--accent);
    font-weight: 500;
    background: var(--border-color);
  }

  .toc-depth-3 {
    padding-left: var(--space-3);
  }

  .toc-depth-4 {
    padding-left: var(--space-5);
  }

  /* Custom scrollbar */
  .toc::-webkit-scrollbar {
    width: 3px;
  }

  .toc::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 2px;
  }

  .toc::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }

  @media (max-width: 1200px) {
    .toc {
      display: none;
    }
  }
</style>
