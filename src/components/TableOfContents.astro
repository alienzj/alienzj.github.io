---
interface Props {
  title?: string;
}

const { title = 'On this page' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-title">{title}</div>
  <ul class="toc-list" id="toc-list">
    <!-- TOC items will be populated by JavaScript -->
  </ul>
</nav>

<script>
  interface TOCItem {
    id: string;
    text: string;
    depth: number;
    element: Element;
  }

  let tocItems: TOCItem[] = [];
  let activeId: string | null = null;

  function generateTOC() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    const article = document.querySelector('article.blog-main');
    if (!article) return;

    const headings = article.querySelectorAll('h2, h3, h4');
    if (headings.length === 0) {
      const tocEl = document.querySelector('.toc');
      if (tocEl) tocEl.style.display = 'none';
      return;
    }

    tocItems = Array.from(headings).map(heading => {
      // Generate ID if not present
      if (!heading.id) {
        heading.id = heading.textContent
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '');
      }

      return {
        id: heading.id,
        text: heading.textContent || '',
        depth: parseInt(heading.tagName.charAt(1)),
        element: heading
      };
    });

    tocList.innerHTML = '';
    tocItems.forEach(item => {
      const li = document.createElement('li');
      li.className = `toc-item toc-depth-${item.depth}`;
      li.dataset.tocId = item.id;

      const a = document.createElement('a');
      a.href = `#${item.id}`;
      a.textContent = item.text;
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(item.id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Update URL without scrolling
          history.pushState(null, '', `#${item.id}`);
        }
      });

      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Initialize scroll spy
    initScrollSpy();
  }

  function initScrollSpy() {
    // Calculate offset for scroll position
    const getOffsetTop = (element: Element): number => {
      const article = document.querySelector('article.blog-main');
      if (!article) return 0;
      
      const articleRect = article.getBoundingClientRect();
      const elementRect = element.getBoundingClientRect();
      return elementRect.top - articleRect.top + article.scrollTop;
    };

    const handleScroll = () => {
      const article = document.querySelector('article.blog-main');
      if (!article) return;

      const scrollPosition = article.scrollTop;
      const viewportHeight = article.clientHeight;

      // Find the active heading
      let currentId: string | null = null;
      
      for (let i = tocItems.length - 1; i >= 0; i--) {
        const item = tocItems[i];
        const offsetTop = getOffsetTop(item.element);
        
        // Consider heading active if it's within the top 30% of viewport
        if (offsetTop <= scrollPosition + viewportHeight * 0.15) {
          currentId = item.id;
          break;
        }
      }

      // Update active state
      if (currentId !== activeId) {
        activeId = currentId;
        updateActiveLink();
      }
    };

    const article = document.querySelector('article.blog-main');
    if (article) {
      article.addEventListener('scroll', handleScroll, { passive: true });
    }

    // Initial check
    setTimeout(handleScroll, 100);
  }

  function updateActiveLink() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    // Remove active class from all links
    tocList.querySelectorAll('.toc-item a').forEach(link => {
      link.classList.remove('active');
    });

    // Add active class to current link
    if (activeId) {
      const activeLink = tocList.querySelector(`a[href="#${activeId}"]`);
      if (activeLink) {
        activeLink.classList.add('active');
        
        // Scroll active item into view if needed
        const tocContainer = document.querySelector('.toc');
        if (tocContainer) {
          const linkRect = activeLink.getBoundingClientRect();
          const containerRect = tocContainer.getBoundingClientRect();
          
          if (linkRect.top < containerRect.top || linkRect.bottom > containerRect.bottom) {
            activeLink.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
        }
      }
    }
  }

  // Run on page load
  generateTOC();

  // Re-run after Astro page transitions
  document.addEventListener('astro:page-load', generateTOC);
</script>

<style>
  .toc {
    position: sticky;
    top: var(--space-6);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: var(--space-4);
    max-height: calc(100vh - var(--space-12));
    overflow-y: auto;
    transition: border-color 0.2s;
  }

  .toc:hover {
    border-color: var(--text-muted);
  }

  .toc-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-item a {
    display: block;
    padding: var(--space-1) var(--space-2);
    margin: 0 calc(-1 * var(--space-2));
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1.5;
    border-radius: 4px;
    transition: all 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--text-primary);
    background: var(--border-color);
  }

  .toc-item a.active {
    color: var(--text-primary);
    font-weight: 500;
    background: var(--border-color);
  }

  .toc-depth-3 {
    padding-left: var(--space-4);
  }

  .toc-depth-4 {
    padding-left: var(--space-6);
  }

  /* Custom scrollbar */
  .toc::-webkit-scrollbar {
    width: 4px;
  }

  .toc::-webkit-scrollbar-track {
    background: transparent;
  }

  .toc::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 2px;
  }

  .toc::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }

  @media (max-width: 1200px) {
    .toc {
      display: none;
    }
  }
</style>
