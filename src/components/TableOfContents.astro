---
interface Props {
  title?: string;
}

const { title = 'On this page' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-header">{title}</div>
  <ul class="toc-list" id="toc-list"></ul>
</nav>

<script is:inline>
  (function() {
    let items = [];
    let activeId = null;
    let ticking = false;
    const offset = 100;

    function slugify(s) {
      return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    }

    function init() {
      const list = document.getElementById('toc-list');
      if (!list) return;

      const article = document.querySelector('article.blog-main') || document.querySelector('article');
      if (!article) {
        const toc = document.querySelector('.toc');
        if (toc) toc.style.display = 'none';
        return;
      }

      const headings = Array.from(article.querySelectorAll('h2, h3'));
      if (headings.length === 0) {
        const toc = document.querySelector('.toc');
        if (toc) toc.style.display = 'none';
        return;
      }

      items = headings.map((h, i) => {
        if (!h.id) h.id = slugify(h.textContent) || 'h-' + i;
        return {
          id: h.id,
          text: h.textContent,
          depth: parseInt(h.tagName[1]) - 2, // h2 is depth 0
          el: h,
          top: 0
        };
      });

      list.innerHTML = '';
      items.forEach((item, i) => {
        const li = document.createElement('li');
        li.className = 'toc-item depth-' + item.depth;
        li.style.setProperty('--i', i);

        const a = document.createElement('a');
        a.href = '#' + item.id;
        a.className = 'toc-link';
        a.textContent = item.text;
        a.dataset.id = item.id;

        li.appendChild(a);
        list.appendChild(li);
      });

      list.onclick = function(e) {
        const a = e.target.closest('.toc-link');
        if (!a) return;
        e.preventDefault();
        const el = document.getElementById(a.dataset.id);
        if (el) {
          window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - offset, behavior: 'smooth' });
          history.pushState(null, '', '#' + a.dataset.id);
        }
      };

      update();
      addEventListener('scroll', onScroll, { passive: true });
      addEventListener('resize', update, { passive: true });
    }

    function update() {
      items.forEach((item, i) => {
        item.top = item.el.getBoundingClientRect().top + window.scrollY - offset - 10;
      });
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(function() {
          const y = window.scrollY + offset + 20;
          let id = null;
          for (let i = items.length - 1; i >= 0; i--) {
            if (y >= items[i].top) { id = items[i].id; break; }
          }
          if (id !== activeId) {
            activeId = id;
            refresh();
          }
          ticking = false;
        });
        ticking = true;
      }
    }

    function refresh() {
      const list = document.getElementById('toc-list');
      if (!list) return;
      list.querySelectorAll('.toc-link').forEach(a => a.classList.remove('active'));
      if (activeId) {
        const a = list.querySelector('[data-id="' + activeId + '"]');
        if (a) {
          a.classList.add('active');
        }
      }
    }

    document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
    document.addEventListener('astro:page-load', init);
    document.addEventListener('astro:after-swap', init);
  })();
</script>

<style>
  .toc {
    font-size: 0.875rem;
  }

  .toc-header {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .toc-link {
    display: block;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s;
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--text-primary);
  }

  .toc-link.active {
    color: var(--accent);
    font-weight: 500;
  }

  .depth-1 .toc-link {
    padding-left: var(--space-4);
    font-size: 0.8rem;
  }

  @media (max-width: 1100px) {
    .toc { display: none; }
  }
</style>