---
interface Props {
  title?: string;
}

const { title = 'Contents' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-title">{title}</div>
  <ul class="toc-list" id="toc-list">
    <!-- TOC items will be populated by JavaScript -->
  </ul>
</nav>

<script>
  function generateTOC() {
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    const article = document.querySelector('article');
    if (!article) return;

    const headings = article.querySelectorAll('h2, h3, h4');
    if (headings.length === 0) {
      tocList.parentElement.style.display = 'none';
      return;
    }

    headings.forEach(heading => {
      // Generate ID if not present
      if (!heading.id) {
        heading.id = heading.textContent
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '');
      }

      const li = document.createElement('li');
      li.className = `toc-item toc-depth-${heading.tagName.toLowerCase()}`;

      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;

      li.appendChild(a);
      tocList.appendChild(li);
    });
  }

  // Run on page load
  generateTOC();

  // Also run after Astro page transitions (if applicable)
  document.addEventListener('astro:page-load', generateTOC);
</script>

<style>
  .toc {
    position: sticky;
    top: var(--space-6);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: var(--space-4);
    margin-bottom: var(--space-8);
    max-height: calc(100vh - var(--space-12));
    overflow-y: auto;
  }

  .toc-title {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-item a {
    display: block;
    padding: var(--space-1) 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .toc-item a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .toc-depth-h3 {
    padding-left: var(--space-4);
  }

  .toc-depth-h4 {
    padding-left: var(--space-6);
  }

  @media (max-width: 1100px) {
    .toc {
      display: none;
    }
  }
</style>
