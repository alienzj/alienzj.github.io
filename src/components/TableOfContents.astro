---
interface Props {
  title?: string;
}

const { title = 'Contents' } = Astro.props;
---

<nav class="toc" aria-label={title}>
  <div class="toc-header">{title}</div>
  <ul class="toc-list" id="toc-list"></ul>
</nav>

<script is:inline>
  (function() {
    let items = [];
    let activeId = null;
    let ticking = false;
    const offset = 100;

    function slugify(s) {
      return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    }

    function init() {
      const list = document.getElementById('toc-list');
      if (!list) return;

      const article = document.querySelector('article.blog-main') || document.querySelector('article');
      if (!article) {
        document.querySelector('.toc').style.display = 'none';
        return;
      }

      const headings = Array.from(article.querySelectorAll('h2, h3, h4'));
      if (headings.length === 0) {
        document.querySelector('.toc').style.display = 'none';
        return;
      }

      items = headings.map((h, i) => {
        if (!h.id) h.id = slugify(h.textContent) || 'h-' + i;
        return {
          id: h.id,
          text: h.textContent,
          depth: parseInt(h.tagName[1]) - 1,
          el: h,
          top: 0
        };
      });

      list.innerHTML = '';
      items.forEach((item, i) => {
        const li = document.createElement('li');
        li.className = 'toc-item depth-' + item.depth;
        li.style.setProperty('--i', i);

        const a = document.createElement('a');
        a.href = '#' + item.id;
        a.className = 'toc-link';
        a.textContent = item.text;
        a.dataset.id = item.id;

        li.appendChild(a);
        list.appendChild(li);
      });

      list.onclick = function(e) {
        const a = e.target.closest('.toc-link');
        if (!a) return;
        e.preventDefault();
        const el = document.getElementById(a.dataset.id);
        if (el) {
          window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - offset, behavior: 'smooth' });
          history.pushState(null, '', '#' + a.dataset.id);
        }
      };

      update();
      addEventListener('scroll', onScroll, { passive: true });
      addEventListener('resize', update, { passive: true });
    }

    function update() {
      items.forEach((item, i) => {
        item.top = item.el.getBoundingClientRect().top + window.scrollY - offset;
      });
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(function() {
          update();
          const y = window.scrollY + offset + 20;
          let id = null;
          for (let i = items.length - 1; i >= 0; i--) {
            if (y >= items[i].top) { id = items[i].id; break; }
          }
          if (id !== activeId) {
            activeId = id;
            refresh();
          }
          ticking = false;
        });
        ticking = true;
      }
    }

    function refresh() {
      const list = document.getElementById('toc-list');
      if (!list) return;
      list.querySelectorAll('.toc-link').forEach(a => a.classList.remove('active'));
      if (activeId) {
        const a = list.querySelector('[data-id="' + activeId + '"]');
        if (a) {
          a.classList.add('active');
          a.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }
    }

    document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
    document.addEventListener('astro:page-load', init);
    document.addEventListener('astro:after-swap', init);
  })();
</script>

<style>
  .toc {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }

  .toc-header {
    padding: 10px 14px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    background: var(--bg-primary);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 6px 0;
  }

  .toc-item {
    animation: fade-in 0.2s ease forwards;
    animation-delay: calc(var(--i) * 20ms);
    opacity: 0;
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  .toc-link {
    display: block;
    padding: 5px 14px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s;
  }

  .toc-link:hover {
    color: var(--text-primary);
    background: var(--bg-secondary);
  }

  .toc-link.active {
    color: var(--accent);
    font-weight: 500;
    border-left-color: var(--accent);
    background: var(--bg-secondary);
  }

  .depth-1 .toc-link { padding-left: 24px; }
  .depth-2 .toc-link { padding-left: 32px; font-size: 0.7rem; }

  .toc::-webkit-scrollbar { width: 3px; }
  .toc::-webkit-scrollbar-track { background: transparent; }
  .toc::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 2px; }

  @media (max-width: 960px) {
    .toc { display: none; }
  }
</style>