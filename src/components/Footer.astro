---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="copyright">
			&copy; {today.getFullYear()} alienzj. Microbiome Informatics Researcher.
		</div>
		<div class="social-links">
			<a href="https://github.com/alienzj" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">GitHub</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
			</a>
			<a href="mailto:your.email@example.com">
				<span class="sr-only">Email</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
			</a>
			<a href="/rss.xml">
				<span class="sr-only">RSS</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
			</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: var(--space-12) var(--space-6);
		border-top: 1px solid var(--border);
	}

	.footer-content {
		max-width: var(--max-width-site);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-6);
	}

	.copyright {
		color: var(--text-muted);
		font-size: 0.875rem;
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: var(--space-6);
	}

	.social-links a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.social-links a:hover {
		color: var(--text-primary);
	}

	@media (min-width: 640px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>
